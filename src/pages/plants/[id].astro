---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { plants, MONTHS, MONTH_LABELS } from "../../data/plants";
import type { Month } from "../../data/plants";

export function getStaticPaths() {
	return plants.map((plant) => ({
		params: { id: plant.id },
		props: { plant },
	}));
}

const { plant } = Astro.props;

function getCellClass(month: Month): string {
	const s = plant.schedule;
	if (s.harvest.includes(month)) return "harvest";
	if (s.transplant.includes(month)) return "transplant";
	if (s.sowOutdoors.includes(month)) return "sow-outdoors";
	if (s.sowIndoors.includes(month)) return "sow-indoors";
	return "empty";
}

function getCellLabel(month: Month): string {
	const s = plant.schedule;
	if (s.harvest.includes(month)) return "Harvest";
	if (s.transplant.includes(month)) return "Transplant";
	if (s.sowOutdoors.includes(month)) return "Sow Outdoors";
	if (s.sowIndoors.includes(month)) return "Sow Indoors";
	return "";
}
---

<BaseLayout title={plant.name}>
	<main>
		<section class="header">
			<h1>{plant.name}</h1>
			<p class="scientific"><em>{plant.scientificName}</em></p>
			<p class="family">Family: {plant.family} &middot; Genus: {plant.genus}</p>
		</section>

		<section class="details">
			<img src={plant.imageUrl} alt={plant.name} />
			<div class="details-text">
				<p class="description">{plant.description}</p>
			</div>
		</section>

		<section class="info-grid">
			<div class="info-card">
				<h3>Soil Temperature</h3>
				<p>{plant.soilTemp.min}&deg;C &ndash; {plant.soilTemp.max}&deg;C</p>
			</div>
			<div class="info-card">
				<h3>Spacing</h3>
				<p>{plant.spacing.min} &ndash; {plant.spacing.max} cm</p>
			</div>
			<div class="info-card">
				<h3>Harvest</h3>
				<p>{plant.harvestWeeks.min}&ndash;{plant.harvestWeeks.max} weeks</p>
			</div>
			<div class="info-card">
				<h3>Sowing</h3>
				<p>{plant.sowingMethod}</p>
			</div>
		</section>

		<section class="schedule-section">
			<h2>Growing Schedule <span class="zone-badge">Zone 7b/8a</span></h2>

			<div class="legend">
				<span class="legend-item"><span class="swatch sow-indoors"></span> Sow Indoors</span>
				<span class="legend-item"><span class="swatch sow-outdoors"></span> Sow Outdoors</span>
				<span class="legend-item"><span class="swatch transplant"></span> Transplant</span>
				<span class="legend-item"><span class="swatch harvest"></span> Harvest</span>
			</div>

			<div class="month-grid">
				{MONTHS.map((m) => {
					const cellClass = getCellClass(m);
					const label = getCellLabel(m);
					return (
						<div class:list={["month-cell", cellClass]}>
							<span class="month-label">{MONTH_LABELS[m]}</span>
							{label && <span class="cell-label">{label}</span>}
						</div>
					);
				})}
			</div>
		</section>

		{plant.companions.length > 0 && (
			<section class="companions-section">
				<h2>Companions</h2>
				<div class="tag-list">
					{plant.companions.map((c) => (
						<span class="tag companion">{c}</span>
					))}
				</div>
			</section>
		)}

		{plant.incompatible.length > 0 && (
			<section class="incompatible-section">
				<h2>Avoid Growing Near</h2>
				<div class="tag-list">
					{plant.incompatible.map((i) => (
						<span class="tag avoid">{i}</span>
					))}
				</div>
			</section>
		)}

		<section class="growing-notes">
			<h2>Growing Notes</h2>
			<div class="notes-content" set:html={plant.gardenateDescription.split('\n').map(p => `<p>${p}</p>`).join('')} />
		</section>

		<section class="culinary">
			<h2>Culinary Hints</h2>
			<p>{plant.culinaryHints}</p>
		</section>

		<div class="source-link">
			<a href={plant.gardenateUrl} target="_blank" rel="noopener noreferrer">
				View on Gardenate
			</a>
		</div>

		<div class="nav-links">
			<a href="/plants" class="back-link">Back to plant database</a>
			<a href="/schedule" class="back-link">View full schedule</a>
		</div>
	</main>
</BaseLayout>

<style>
	main {
		padding: 2rem;
		max-width: 800px;
		margin: 0 auto;
	}

	.header h1 {
		font-size: 2.2rem;
		margin: 0 0 0.3rem;
		color: #a7f3d0;
	}

	.scientific {
		color: #9ca3af;
		font-size: 1.1rem;
		margin: 0 0 0.3rem;
	}

	.family {
		color: #6b7280;
		font-size: 0.9rem;
		margin: 0;
	}

	.details {
		display: flex;
		gap: 1.5rem;
		align-items: flex-start;
		margin: 2rem 0;
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.03);
		border-radius: 8px;
		border: 1px solid #1e2d1e;
	}

	.details img {
		width: 180px;
		height: 180px;
		object-fit: cover;
		border-radius: 6px;
		flex-shrink: 0;
	}

	.details-text {
		flex: 1;
	}

	.description {
		color: #d1d5db;
		line-height: 1.6;
		margin: 0;
	}

	.info-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
		gap: 0.75rem;
		margin: 1.5rem 0;
	}

	.info-card {
		padding: 1rem;
		background: rgba(255, 255, 255, 0.03);
		border-radius: 6px;
		border: 1px solid #1e2d1e;
	}

	.info-card h3 {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #6ee7b7;
		margin: 0 0 0.4rem;
		font-weight: 600;
	}

	.info-card p {
		color: #d1d5db;
		margin: 0;
		font-size: 0.9rem;
	}

	.schedule-section {
		margin: 2rem 0;
	}

	.schedule-section h2 {
		font-size: 1.3rem;
		color: #e0e0e0;
		margin: 0 0 1rem;
		display: flex;
		align-items: center;
		gap: 0.7rem;
	}

	.zone-badge {
		font-size: 0.7rem;
		background: rgba(74, 222, 128, 0.15);
		color: #6ee7b7;
		padding: 0.2rem 0.5rem;
		border-radius: 4px;
		font-weight: 500;
	}

	.legend {
		display: flex;
		gap: 1rem;
		margin-bottom: 1rem;
		flex-wrap: wrap;
	}

	.legend-item {
		display: flex;
		align-items: center;
		gap: 0.35rem;
		font-size: 0.78rem;
		color: #9ca3af;
	}

	.swatch {
		width: 12px;
		height: 12px;
		border-radius: 2px;
	}

	.swatch.sow-indoors {
		background: #2563eb;
	}
	.swatch.sow-outdoors {
		background: #16a34a;
	}
	.swatch.transplant {
		background: #d97706;
	}
	.swatch.harvest {
		background: #dc2626;
	}

	.month-grid {
		display: grid;
		grid-template-columns: repeat(12, 1fr);
		gap: 4px;
	}

	.month-cell {
		padding: 0.6rem 0.3rem;
		border-radius: 5px;
		text-align: center;
		min-height: 60px;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.25rem;
		transition: transform 0.12s ease;
	}

	.month-cell:hover {
		transform: scale(1.08);
	}

	.month-cell.empty {
		background: rgba(255, 255, 255, 0.03);
	}

	.month-cell.sow-indoors {
		background: #2563eb;
	}
	.month-cell.sow-outdoors {
		background: #16a34a;
	}
	.month-cell.transplant {
		background: #d97706;
	}
	.month-cell.harvest {
		background: #dc2626;
	}

	.month-label {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.cell-label {
		font-size: 0.6rem;
		opacity: 0.85;
	}

	.companions-section,
	.incompatible-section {
		margin: 1.5rem 0;
	}

	.companions-section h2,
	.incompatible-section h2 {
		font-size: 1.1rem;
		color: #e0e0e0;
		margin: 0 0 0.75rem;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.tag {
		padding: 0.3rem 0.7rem;
		border-radius: 4px;
		font-size: 0.8rem;
		color: #d1d5db;
	}

	.tag.companion {
		background: rgba(22, 163, 74, 0.15);
		border: 1px solid rgba(22, 163, 74, 0.3);
	}

	.tag.avoid {
		background: rgba(220, 38, 38, 0.1);
		border: 1px solid rgba(220, 38, 38, 0.25);
		color: #fca5a5;
	}

	.growing-notes,
	.culinary {
		margin: 1.5rem 0;
	}

	.growing-notes h2,
	.culinary h2 {
		font-size: 1.1rem;
		color: #e0e0e0;
		margin: 0 0 0.75rem;
	}

	.notes-content p,
	.culinary p {
		color: #d1d5db;
		line-height: 1.7;
		margin: 0 0 0.75rem;
	}

	.source-link {
		margin: 2rem 0 1rem;
	}

	.source-link a {
		display: inline-block;
		color: #4ade80;
		text-decoration: none;
		font-size: 0.9rem;
		padding: 0.5rem 1rem;
		border: 1px solid rgba(74, 222, 128, 0.3);
		border-radius: 6px;
		transition: background 0.15s ease;
	}

	.source-link a:hover {
		background: rgba(74, 222, 128, 0.1);
		text-decoration: none;
	}

	.nav-links {
		margin-top: 1.5rem;
	}

	.back-link {
		display: inline-block;
		color: #4ade80;
		text-decoration: none;
		margin-right: 1rem;
		font-size: 0.9rem;
	}

	.back-link:hover {
		text-decoration: underline;
	}

	@media (max-width: 600px) {
		.details {
			flex-direction: column;
		}

		.details img {
			width: 100%;
			height: auto;
		}

		.month-grid {
			grid-template-columns: repeat(6, 1fr);
		}
	}
</style>
